# App URL (used in reset-password links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5433/shackles_local?schema=public

# Session / Auth (generate a strong random value, min 32 chars)
SESSION_SECRET=replace-with-strong-random-secret

# Storage provider selector: local | digitalocean
STORAGE_PROVIDER=digitalocean

# DigitalOcean Spaces (required when STORAGE_PROVIDER=digitalocean)
DO_SPACES_REGION=sgp1
DO_SPACES_BUCKET=your-bucket-name
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_KEY=replace-with-spaces-key
DO_SPACES_SECRET=replace-with-spaces-secret
DO_SPACES_CDN_BASE_URL=https://your-bucket-name.sgp1.cdn.digitaloceanspaces.com

# SMTP (email sending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=replace-with-app-password
