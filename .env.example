# ====================================
# Core Configuration
# ====================================

# App URL (used in reset-password links and email)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# Database (use docker-compose for local development)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5433/shackles_local?schema=public

# Session / Auth (generate a strong random value, min 32 characters)
# Example: openssl rand -base64 32
SESSION_SECRET=replace-with-strong-random-secret
