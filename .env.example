# ====================================
# Core Configuration
# ====================================

# App URL (used in reset-password links and email)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# Database (use docker-compose for local development)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5433/shackles_local?schema=public

# Session / Auth (generate a strong random value, min 32 characters)
# Example: openssl rand -base64 32
SESSION_SECRET=replace-with-strong-random-secret

# ====================================
# Yearly / Edition Controls (Production Required)
# ====================================

# Event year (e.g., 2026)
ACTIVE_YEAR=2026

# Theme identifier (e.g., "default", "winter", etc)
ACTIVE_THEME_KEY=default

# Public domain for serving event images
ACTIVE_PUBLIC_DOMAIN=localhost:3000

# ====================================
# Feature Flags
# ====================================

# Enable scanner bulk team registration workflow (true/false)
ENABLE_SCANNER_BULK_TEAM_FLOW=false

# ====================================
# Storage Configuration
# ====================================

# Storage provider: local | digitalocean
STORAGE_PROVIDER=local

# DigitalOcean Spaces (required when STORAGE_PROVIDER=digitalocean)
# DO_SPACES_REGION=sgp1
# DO_SPACES_BUCKET=your-bucket-name
# DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
# DO_SPACES_KEY=replace-with-spaces-key
# DO_SPACES_SECRET=replace-with-spaces-secret
# DO_SPACES_CDN_BASE_URL=https://your-bucket-name.sgp1.cdn.digitaloceanspaces.com

# ====================================
# Email Configuration (SMTP)
# ====================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=replace-with-app-password

# ====================================
# AI / ML Configuration (Optional)
# ====================================

# Pinecone API key for vector search (optional, AI features degraded if missing)
# PINECONE_API_KEY=replace-with-pinecone-key

# Pinecone index name
# PINECONE_INDEX=shackles-events

# ====================================
# Redis Configuration (Rate Limiting & Caching)
# ====================================

# For local development with docker-compose, use default Redis connection
# For production with Upstash, set these:
# UPSTASH_REDIS_REST_URL=https://your-cluster.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# ====================================
# Testing Environment Overrides (Playwright)
# ====================================

# Optional: Override database URL for Playwright tests (separate test DB)
# PLAYWRIGHT_DATABASE_URL=postgresql://postgres:password@localhost:5433/shackles_test?schema=public

# Optional: Override session secret for Playwright tests
# PLAYWRIGHT_SESSION_SECRET=test-session-secret

# Optional: Override SMTP for Playwright tests
# PLAYWRIGHT_SMTP_HOST=smtp.test.local
# PLAYWRIGHT_SMTP_PORT=1025
# PLAYWRIGHT_SMTP_USER=test@example.com
# PLAYWRIGHT_SMTP_PASS=test-password
