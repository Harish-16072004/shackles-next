# =============================================================================
# Shackles Symposium — Environment Variables Reference
# =============================================================================
# Copy this file to .env.local for development.
# NEVER commit .env.local or any file containing real secrets.

# App URL (used in reset-password links and PWA metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# DATABASE_URL      → used at RUNTIME by the Next.js app (can be a pooler URL)
# DIRECT_DATABASE_URL → used by "prisma migrate" / "prisma db push" (direct TCP)
#
# Local development (no pooler needed):
DATABASE_URL=postgresql://postgres:password@localhost:5433/shackles_local
DIRECT_DATABASE_URL=postgresql://postgres:password@localhost:5433/shackles_local
#
# --- Production option A: Prisma Accelerate ---
# DATABASE_URL=prisma://accelerate.prisma-data.net/?api_key=<YOUR_API_KEY>
# DIRECT_DATABASE_URL=postgresql://user:pass@host:5432/shackles_symposium
#
# --- Production option B: PgBouncer (transaction mode) ---
# DATABASE_URL=postgresql://user:pass@host:6432/shackles_symposium?pgbouncer=true
# DIRECT_DATABASE_URL=postgresql://user:pass@host:5432/shackles_symposium
#
# --- Production option C: Supabase pooler ---
# DATABASE_URL=postgresql://postgres:[PASS]@db.[REF].supabase.co:6543/postgres?pgbouncer=true
# DIRECT_DATABASE_URL=postgresql://postgres:[PASS]@db.[REF].supabase.co:5432/postgres
#
# --- Production option D: Neon pooler ---
# DATABASE_URL=postgresql://[user]:[pass]@[endpoint]-pooler.neon.tech/shackles?sslmode=require
# DIRECT_DATABASE_URL=postgresql://[user]:[pass]@[endpoint].neon.tech/shackles?sslmode=require

# Session / Auth (generate a strong random value — minimum 32 characters)
SESSION_SECRET=replace-with-strong-random-secret-32chars
