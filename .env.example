# ====================================
# Yearly / Edition Controls (Production Required)
# ====================================

# Event year (e.g., 2026)
ACTIVE_YEAR=2026

# Theme identifier (e.g., "default", "winter", etc)
ACTIVE_THEME_KEY=default

# Public domain for serving event images
ACTIVE_PUBLIC_DOMAIN=localhost:3000

# ====================================
# Feature Flags
# ====================================

# Enable scanner bulk team registration workflow (true/false)
ENABLE_SCANNER_BULK_TEAM_FLOW=false

# ====================================
# Storage Configuration
# ====================================

# Storage provider: local | digitalocean
STORAGE_PROVIDER=local

# DigitalOcean Spaces (required when STORAGE_PROVIDER=digitalocean)
# DO_SPACES_REGION=sgp1
# DO_SPACES_BUCKET=your-bucket-name
# DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
# DO_SPACES_KEY=replace-with-spaces-key
# DO_SPACES_SECRET=replace-with-spaces-secret
# DO_SPACES_CDN_BASE_URL=https://your-bucket-name.sgp1.cdn.digitaloceanspaces.com

# ====================================
# Email Configuration (SMTP)
# ====================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=replace-with-app-password

