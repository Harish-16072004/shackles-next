// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  APPLICANT      // Registered but pending payment check
  PARTICIPANT    // Verified (Has QR Code)
  ADMIN          // Super User
  COORDINATOR    // Event Manager
}

// --- NEW ENUM ---
enum RegistrationType {
  GENERAL
  WORKSHOP
  COMBO
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum KitStatus {
  PENDING
  ISSUED
}

enum EventParticipationMode {
  INDIVIDUAL
  TEAM
}

enum TeamStatus {
  DRAFT
  COMPLETED
  LOCKED
}

enum TeamMemberRole {
  LEADER
  MEMBER
}

model User {
  id            String    @id @default(cuid())
  
  // --- 1. Personal Details ---
  firstName     String
  lastName      String
  email         String    @unique
  phone         String
  password      String
  
  // --- 2. Education ---
  collegeName   String
  collegeLoc    String
  department    String
  yearOfStudy   String
  
  // --- 3. System Fields ---
  role          Role      @default(APPLICANT)
  
  // --- NEW FIELD ---
  registrationType RegistrationType @default(GENERAL)
  
  shacklesId    String?   @unique // Generated by Admin (e.g. SH26GN001)
  
  // --- 4. Security (Dynamic QR) ---
  qrToken       String?   @unique 
  qrImageUrl    String?
  qrPath        String?
  qrTokenExpiry DateTime?
  lastQrScan    DateTime?
  
  // --- 5. Event Logistics ---
  kitStatus     KitStatus @default(PENDING)
  kitIssuedAt   DateTime?
  kitIssuedBy   String?   
  
  // --- 6. Meta ---
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  payment       Payment?
  
  // Tokens
  verificationToken String? @unique
  resetToken        String? @unique
  resetTokenExpiry  DateTime?

  // Accommodation
  accommodation Accommodation?

  // Events
  registrations EventRegistration[]
  teamsLed      Team[] @relation("TeamLeader")
  teamInvitesSent TeamInvite[] @relation("TeamInviteSender")
  teamInvitesUsed TeamInvite[] @relation("TeamInviteConsumer")

  // Contact Messages
  contactMessages ContactMessage[]
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  mobile    String
  message   String
  createdAt DateTime @default(now())

  // Optional: Link to a registered user if email matches
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
}

model Payment {
  id            String        @id @default(cuid())
  amount        Int
  transactionId String
  proofUrl      String
  proofPath     String?
  status        PaymentStatus @default(PENDING)
  
  verifiedAt    DateTime?
  verifiedBy    String?       
  rejectedAt    DateTime?
  rejectionReason String?

  user          User          @relation(fields: [userId], references: [id])
  userId        String        @unique
  
  createdAt     DateTime      @default(now())
}

model Accommodation {
  id        String   @id @default(cuid())
  
  gender    String   // "MALE" or "FEMALE"
  days      String[] // Stores ["DAY1"] or ["DAY1", "DAY2"]
  
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  
  createdAt DateTime @default(now())
}
// --- NEW MODELS FOR LOGISTICS ---

model Event {
  id          String   @id @default(cuid())
  name        String   @unique // 'Paper Presentation', 'Aqua Missile'
  type        String?  // 'TECHNICAL', 'NON-TECHNICAL', 'SPECIAL', 'WORKSHOP'
  dayLabel    String?
  date        DateTime?
  endDate     DateTime?
  description String?
  rulesUrl    String?
  coordinatorName String?
  coordinatorPhone String?
  trainerName String?
  contactName String?
  contactPhone String?
  participationMode EventParticipationMode @default(INDIVIDUAL)
  isAllDay   Boolean  @default(false)
  teamMinSize Int?
  teamMaxSize Int?
  maxTeams    Int?
  maxParticipants Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  registrations EventRegistration[]
  teams       Team[]
}

model Team {
  id                       String     @id @default(cuid())
  event                    Event      @relation(fields: [eventId], references: [id])
  eventId                  String
  name                     String
  nameNormalized           String
  teamCode                 String
  memberCount              Int        @default(0)
  status                   TeamStatus @default(DRAFT)
  leader                   User?      @relation("TeamLeader", fields: [leaderUserId], references: [id])
  leaderUserId             String?
  leaderContactPhoneSnapshot String?
  leaderContactEmailSnapshot String?
  lockedAt                 DateTime?
  lockedBy                 String?
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
  members                  EventRegistration[]
  invites                  TeamInvite[]

  @@unique([eventId, nameNormalized])
  @@unique([eventId, teamCode])
}

model TeamInvite {
  id              String    @id @default(cuid())
  team            Team      @relation(fields: [teamId], references: [id])
  teamId          String
  token           String    @unique
  invitedEmail    String?
  invitedByUser   User      @relation("TeamInviteSender", fields: [invitedByUserId], references: [id])
  invitedByUserId String
  usedByUser      User?     @relation("TeamInviteConsumer", fields: [usedByUserId], references: [id])
  usedByUserId    String?
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime  @default(now())

  @@index([teamId])
  @@index([invitedByUserId])
  @@index([invitedEmail])
}

model EventRegistration {
  id        String   @id @default(cuid())
  
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  
  event     Event    @relation(fields: [eventId], references: [id])
  eventId   String

  team      Team?    @relation(fields: [teamId], references: [id])
  teamId    String?
  memberRole TeamMemberRole?

  teamName  String?
  teamSize  Int      @default(1)
  
  attended  Boolean  @default(false)
  attendedAt DateTime?

  @@unique([userId, eventId]) // Prevent duplicate registration
}
