// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  APPLICANT      // Registered but pending payment check
  PARTICIPANT    // Verified (Has QR Code)
  ADMIN          // Super User
  COORDINATOR    // Event Manager
}

// --- NEW ENUM ---
enum RegistrationType {
  GENERAL
  WORKSHOP
  COMBO
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum KitStatus {
  PENDING
  ISSUED
}

model User {
  id            String    @id @default(cuid())
  
  // --- 1. Personal Details ---
  firstName     String
  lastName      String
  email         String    @unique
  phone         String
  password      String
  
  // --- 2. Education ---
  collegeName   String
  collegeLoc    String
  department    String
  yearOfStudy   String
  
  // --- 3. System Fields ---
  role          Role      @default(APPLICANT)
  
  // --- NEW FIELD ---
  registrationType RegistrationType @default(GENERAL)
  
  shacklesId    String?   @unique // Generated by Admin (e.g. SH26GN001)
  
  // --- 4. Security (Dynamic QR) ---
  qrToken       String?   @unique 
  qrTokenExpiry DateTime?
  lastQrScan    DateTime?
  
  // --- 5. Event Logistics ---
  kitStatus     KitStatus @default(PENDING)
  kitIssuedAt   DateTime?
  kitIssuedBy   String?   
  
  // --- 6. Meta ---
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  payment       Payment?
  
  // Tokens
  verificationToken String? @unique
  resetToken        String? @unique
  resetTokenExpiry  DateTime?

  // Accommodation
  accommodation Accommodation?
}

model Payment {
  id            String        @id @default(cuid())
  amount        Int
  transactionId String
  proofUrl      String        
  status        PaymentStatus @default(PENDING)
  
  verifiedAt    DateTime?
  verifiedBy    String?       
  rejectedAt    DateTime?
  rejectionReason String?

  user          User          @relation(fields: [userId], references: [id])
  userId        String        @unique
  
  createdAt     DateTime      @default(now())
}

model Accommodation {
  id        String   @id @default(cuid())
  
  gender    String   // "MALE" or "FEMALE"
  days      String[] // Stores ["DAY1"] or ["DAY1", "DAY2"]
  
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  
  createdAt DateTime @default(now())
}